PORT=8318
HOST=0.0.0.0
UPSTREAM_BASE_URL=https://api.example.com/v1
UPSTREAM_API_KEY=
PROVIDER_USAGE_CHECK_URL=
PROVIDER_USAGE_CHECK_ENABLED=true
REQUEST_TIMEOUT_MS=300000
SUMMARY_REQUEST_TIMEOUT_MS=900000
STREAM_IDLE_TIMEOUT_MS=330000
HERMES_EXTEND_SUMMARY_TIMEOUT=true
LOG_LEVEL=info
LOG_BODY=false
CHATGPT_OAUTH_ENABLED=true
OPENCLAW_TOKEN_OPTIMIZATION_ENABLED=true
OPENCLAW_DEFAULT_REASONING_SUMMARY=auto
OPENCLAW_DEFAULT_TEXT_VERBOSITY=low
# OPENCLAW_DEFAULT_MAX_OUTPUT_TOKENS=1200
OPENCLAW_AUTO_PROMPT_CACHE_KEY=true
OPENCLAW_PROMPT_CACHE_RETENTION=24h
PROVIDER_PROMPT_CACHE_REDESIGN_ENABLED=false
PROVIDER_PROMPT_CACHE_STABLE_SUMMARIZATION_ENABLED=false
PROVIDER_PROMPT_CACHE_INFLIGHT_DEDUPE_ENABLED=true
PROVIDER_PROMPT_CACHE_RETENTION_BY_FAMILY_ENABLED=false
PROVIDER_PROMPT_CACHE_SUMMARY_TRIGGER_ITEMS=14
PROVIDER_PROMPT_CACHE_SUMMARY_KEEP_RECENT_ITEMS=6
# PROVIDER_PROMPT_CACHE_RETENTION_BY_FAMILY=family:cx-gpt-5-4-xhigh=72h
MAX_OUTPUT_TOKENS_PARAMETER_MODE_FOR_PROVIDER=
MAX_OUTPUT_TOKENS_PARAMETER_TARGET_FOR_PROVIDER=
STRIP_MAX_OUTPUT_TOKENS_FOR_PROVIDER=false
# Legacy compatibility flag. Prefer MAX_OUTPUT_TOKENS_PARAMETER_MODE_FOR_PROVIDER=strip.
# Example rename:
# MAX_OUTPUT_TOKENS_PARAMETER_MODE_FOR_PROVIDER=rename
# MAX_OUTPUT_TOKENS_PARAMETER_TARGET_FOR_PROVIDER=max_completion_tokens
SANITIZE_REASONING_SUMMARY_FOR_PROVIDER=false
FALLBACK_ENABLED=true
FALLBACK_STATUS_CODES=429,500,502,503,504
# Persist prompt-cache state and provider runtime config on a mounted path.
APP_DB_PATH=./logs/app.sqlite
CUSTOMER_KEY_DB_PATH=./logs/telegram-bot.sqlite

# Hermes should point its provider baseUrl here, not to the upstream directly.
RESPONSES_PROXY_BASE_URL=http://127.0.0.1:8318/v1
TELEGRAM_BOT_TOKEN=
# Optional emergency lockdown. Leave empty for public signup mode.
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
# Owner/admin bootstrap stays in env. Customers are created and managed in the bot DB.
TELEGRAM_OWNER_USER_IDS=
TELEGRAM_ADMIN_USER_IDS=
# Deprecated. Public customers should live in the bot DB, not in env.
TELEGRAM_CUSTOMER_USER_IDS=
TELEGRAM_BOT_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
RESPONSES_PROXY_ADMIN_BASE_URL=http://127.0.0.1:8318
RESPONSES_PROXY_CLIENT_API_KEY=
RESPONSES_PROXY_DEFAULT_MODEL=gpt-5.5
BOT_PUBLIC_SIGNUP_ENABLED=false
BOT_REQUIRE_ADMIN_APPROVAL=true
BOT_DEFAULT_CUSTOMER_ROUTE=customers
BOT_PUBLIC_RESPONSES_BASE_URL=http://127.0.0.1:8318/v1
BOT_PROXY_REQUEST_TIMEOUT_MS=30000
BOT_SESSION_DB_PATH=./logs/telegram-bot.sqlite
BOT_SESSION_TTL_MS=900000
BOT_RATE_LIMIT_WINDOW_MS=60000
BOT_RATE_LIMIT_MAX_REQUESTS=12
BOT_LOG_LEVEL=info
