{
  "name": "responses-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal Fastify proxy for OpenAI-compatible Responses API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "bot:dev": "tsx src/telegram-bot/index.ts",
    "bot:worker:dev": "tsx watch src/telegram-bot/worker.ts",
    "bot:worker": "tsx src/telegram-bot/worker.ts",
    "bot:start": "node dist/telegram-bot/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test $(find src -name '*.test.ts' -print)",
    "app:install": "./scripts/install.sh",
    "app:start": "./scripts/start.sh",
    "app:stop": "./scripts/stop.sh",
    "app:status": "./scripts/status.sh",
    "app:logs": "./scripts/logs.sh",
    "app:open": "./scripts/open.sh",
    "tailnet:serve": "./scripts/tailnet-serve.sh",
    "tailnet:funnel": "./scripts/tailnet-funnel.sh",
    "tailnet:status": "./scripts/tailnet-status.sh",
    "tailnet:open": "./scripts/tailnet-open.sh",
    "tailnet:reset": "./scripts/tailnet-reset.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.6.1",
    "grammy": "^1.42.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
