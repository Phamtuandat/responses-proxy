# Production release checklist for the public Telegram bot launch.
# Fill the values below, then deploy with:
#   docker compose up -d --build responses-proxy telegram-bot telegram-bot-worker

########################################
# Required upstream proxy config
########################################

UPSTREAM_BASE_URL=https://api.example.com/v1
UPSTREAM_API_KEY=

########################################
# Required Telegram bot bootstrap
########################################

TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_USER_IDS=1283361952
TELEGRAM_ADMIN_USER_IDS=

########################################
# Public bot mode
########################################

BOT_PUBLIC_SIGNUP_ENABLED=true
BOT_REQUIRE_ADMIN_APPROVAL=false
BOT_DEFAULT_CUSTOMER_ROUTE=customers
BOT_PUBLIC_RESPONSES_BASE_URL=https://YOUR_PUBLIC_PROXY_HOST/v1

########################################
# Emergency lockdown
########################################

# Leave empty in normal public mode.
# If needed, set to owner/admin ids only to temporarily block public access.
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=

########################################
# Persistence
########################################

APP_DB_PATH=./logs/app.sqlite
CUSTOMER_KEY_DB_PATH=./logs/telegram-bot.sqlite
BOT_SESSION_DB_PATH=./logs/telegram-bot.sqlite

########################################
# Bot and worker runtime
########################################

RESPONSES_PROXY_ADMIN_BASE_URL=http://responses-proxy:8318
RESPONSES_PROXY_CLIENT_API_KEY=
RESPONSES_PROXY_DEFAULT_MODEL=gpt-5.5
BOT_WORKER_INTERVAL_MS=60000
BOT_WORKER_ONCE=false

########################################
# Safety defaults
########################################

LOG_LEVEL=info
BOT_LOG_LEVEL=info
LOG_BODY=false
PROVIDER_USAGE_CHECK_ENABLED=true
REQUEST_TIMEOUT_MS=300000
STREAM_IDLE_TIMEOUT_MS=330000

########################################
# Optional Telegram webhook settings
# Keep polling for this release unless you are deliberately switching.
########################################

TELEGRAM_BOT_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

########################################
# Deprecated: keep empty
########################################

TELEGRAM_CUSTOMER_USER_IDS=
